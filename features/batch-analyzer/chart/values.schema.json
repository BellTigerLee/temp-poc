{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schedule", "image", "existingSecret", "resources"],
  "properties": {
    "schedule": {"type": "string", "minLength": 1},
    "image": {"$ref": "#/$defs/image"},
    "existingSecret": {"$ref": "#/$defs/existingSecret"},
    "resources": {"$ref": "#/$defs/resources"}
  },
  "$defs": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "sourceRevision"],
      "properties": {
        "repository": {"const": "registry.example.invalid/temp-poc/batch-analyzer"},
        "tag": {"const": "0.1.0-c57dcba"},
        "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "sourceRevision": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "existingSecret": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "key"],
      "properties": {"name": {"type": "string"}, "key": {"type": "string"}}
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "limits"],
      "properties": {
        "requests": {"const": {"cpu": "10m", "memory": "16Mi"}},
        "limits": {"const": {"cpu": "100m", "memory": "64Mi"}}
      }
    }
  }
}
